# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/swades_db

# CORS Configuration - Change to your domain in production
CORS_ORIGIN=http://localhost:3001

# Transcription Services - Configure at least one
# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_xxx_your_key_here

# Alternative: Google Cloud Speech-to-Text
# Get your API key from: https://console.cloud.google.com
# GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key

# Environment
NODE_ENV=development
